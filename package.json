{
  "name": "aida26-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "build": "npm run build:backend && npm run build:frontend",
    "dev": "npm run build && node dist/index.js",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  }
}